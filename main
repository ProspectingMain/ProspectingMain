local function RefreshConfigs()
    for _,c in pairs(ConfigList:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    local configs=GetConfigList(); local currentAuto=GetAutoload()
    for _,name in pairs(configs) do
        local Row=Instance.new("Frame"); Row.Size=UDim2.new(1,0,0,38); Row.BackgroundColor3=Theme.RowBg; Row.ZIndex=32; Row.Parent=ConfigList
        Instance.new("UICorner",Row).CornerRadius=UDim.new(0,8)
        local RStroke=Instance.new("UIStroke"); RStroke.Color=(name==currentAuto) and Theme.Accent or Theme.Stroke
        RStroke.Thickness=1; RStroke.Transparency=(name==currentAuto) and 0.4 or 0.85; RStroke.Parent=Row
        local NameLbl=Instance.new("TextLabel"); NameLbl.Text=name..(name==currentAuto and "  ✦" or "")
        NameLbl.Size=UDim2.new(0.38,0,1,0); NameLbl.Position=UDim2.new(0,10,0,0); NameLbl.BackgroundTransparency=1
        NameLbl.TextColor3=(name==currentAuto and Theme.Accent or Theme.TextMain); NameLbl.TextXAlignment=Enum.TextXAlignment.Left
        NameLbl.Font=Enum.Font.GothamBold; NameLbl.TextSize=12; NameLbl.ZIndex=33; NameLbl.Parent=Row
        local function makeBtn(label,bg,tc,xOff)
            local b=Instance.new("TextButton"); b.Size=UDim2.new(0,44,0,26); b.Position=UDim2.new(1,xOff,0.5,-13)
            b.BackgroundColor3=bg; b.Text=label; b.TextColor3=tc; b.Font=Enum.Font.GothamBold; b.TextSize=11
            b.AutoButtonColor=false; b.ZIndex=33; b.Parent=Row; Instance.new("UICorner",b).CornerRadius=UDim.new(0,6); return b
        end
        local OverB=makeBtn("↑ Save",Color3.fromRGB(28,28,44),Theme.TextDim,-186)
        OverB.MouseButton1Click:Connect(function() SaveConfig(name) end)
        local LoadB=makeBtn("Load",Color3.fromRGB(16,38,28),Theme.Accent,-137)
        LoadB.MouseButton1Click:Connect(function() LoadConfig(name) end)
        local AutoB=makeBtn("Auto",(name==currentAuto and Theme.Accent or Color3.fromRGB(28,28,44)),(name==currentAuto and Color3.fromRGB(8,8,12) or Theme.TextDim),-88)
        AutoB.MouseButton1Click:Connect(function()
            if currentAuto==name then ClearAutoload() else SetAutoload(name) end
            RefreshConfigs()
        end)
        local DelB=makeBtn("Del",Color3.fromRGB(38,14,18),Theme.Red,-39)
        DelB.MouseButton1Click:Connect(function() DeleteConfig(name); RefreshConfigs() end)
    end
    ConfigList.CanvasSize=UDim2.new(0,0,0,CListLayout.AbsoluteContentSize.Y)
end

SaveBtn.MouseButton1Click:Connect(function()
    local name=ConfigInput.Text
    if name=="" then
        local dt=os.date("*t")
        name=string.format("Config_%02d%02d_%02d%02d",dt.month,dt.day,dt.hour,dt.min)
    end
    SaveConfig(name); ConfigInput.Text=""; RefreshConfigs()
end)

