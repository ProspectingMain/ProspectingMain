local function ShowTooltip(text,x,y)
    TooltipLabel.Text=text
    local bounds=game:GetService("TextService"):GetTextSize(text,12,Enum.Font.Gotham,Vector2.new(190,1000))
    TooltipFrame.Size=UDim2.new(0,200,0,bounds.Y+16)
    TooltipFrame.Position=UDim2.new(0,x+15,0,y)
    TooltipFrame.Visible=true
end
local function HideTooltip() TooltipFrame.Visible=false end

