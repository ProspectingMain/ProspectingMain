local function CreateSectionLabel(labelText)
    local lf=Instance.new("Frame"); lf.Size=UDim2.new(1,0,0,26); lf.BackgroundTransparency=1; lf.Parent=Container
    local lineL=Instance.new("Frame"); lineL.Size=UDim2.new(0.22,0,0,1); lineL.Position=UDim2.new(0,0,0.5,0)
    lineL.BackgroundColor3=Theme.Accent; lineL.BorderSizePixel=0; lineL.Parent=lf
    local gradL=Instance.new("UIGradient"); gradL.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.new(0,0,0)),ColorSequenceKeypoint.new(1,Theme.Accent)})
    gradL.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(1,0.6)}); gradL.Parent=lineL
    local lineR=Instance.new("Frame"); lineR.Size=UDim2.new(0.22,0,0,1); lineR.Position=UDim2.new(0.78,0,0.5,0)
    lineR.BackgroundColor3=Theme.Accent; lineR.BorderSizePixel=0; lineR.Parent=lf
    local gradR=Instance.new("UIGradient"); gradR.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Theme.Accent),ColorSequenceKeypoint.new(1,Color3.new(0,0,0))})
    gradR.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.6),NumberSequenceKeypoint.new(1,1)}); gradR.Parent=lineR
    local pill=Instance.new("Frame"); pill.Size=UDim2.new(0.56,0,1,0); pill.Position=UDim2.new(0.22,0,0,0)
    pill.BackgroundColor3=Color3.fromRGB(14,28,22); pill.ZIndex=2; pill.Parent=lf
    Instance.new("UICorner",pill).CornerRadius=UDim.new(1,0)
    local pillStroke=Instance.new("UIStroke"); pillStroke.Color=Theme.Accent; pillStroke.Thickness=1; pillStroke.Transparency=0.65; pillStroke.Parent=pill
    local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1; lbl.Text=labelText
    lbl.TextColor3=Theme.Accent; lbl.Font=Enum.Font.GothamBlack; lbl.TextSize=9; lbl.ZIndex=3; lbl.Parent=pill
end

