local HttpService        = game:GetService("HttpService")
local FolderName         = "SigmaConfigs"

local function ResetAllAutomation()
    local cfg = _G.SigmaFarm_Config
    if cfg then
        cfg.AutoShovel     = false
        cfg.AutoShake      = false
        cfg.AutoSell       = false
        cfg.AutoGeode      = false
        cfg.AutoTotem      = false
        cfg.AutoManualWalk = false
        for k, v in pairs(cfg) do
            if typeof(v) == "boolean" and v then cfg[k] = false end
        end
    end
    _G.SigmaFarm_Running = false
end

pcall(function()
    if not isfolder(FolderName) then makefolder(FolderName) end
end)

