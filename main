local SelectAllBtn=Instance.new("TextButton"); SelectAllBtn.Size=UDim2.new(0.5,-4,1,0); SelectAllBtn.BackgroundColor3=Color3.fromRGB(16,38,28)
SelectAllBtn.Text="Lock Visible"; SelectAllBtn.TextColor3=Theme.Accent; SelectAllBtn.Font=Enum.Font.GothamBold; SelectAllBtn.TextSize=12
