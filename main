local function RefreshFilterList(searchText)
    for _,c in pairs(FilterList:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    if not ValuablesFolder then pcall(function() ValuablesFolder=ReplicatedStorage:FindFirstChild("Items") and ReplicatedStorage.Items:FindFirstChild("Valuables") end) end
    if not ValuablesFolder then return end
    local items={}; for _,v in pairs(ValuablesFolder:GetChildren()) do table.insert(items,v.Name) end; table.sort(items)
    for _,itemName in pairs(items) do
        if not searchText or searchText=="" or string.find(string.lower(itemName),string.lower(searchText)) then
            local locked=Config.LockedItems[itemName]
            local ItemRow=Instance.new("Frame"); ItemRow.Size=UDim2.new(1,0,0,32)
            ItemRow.BackgroundColor3=locked and Color3.fromRGB(14,30,22) or Theme.RowBg; ItemRow.ZIndex=25; ItemRow.Parent=FilterList
            Instance.new("UICorner",ItemRow).CornerRadius=UDim.new(0,7)
            local IStroke=Instance.new("UIStroke"); IStroke.Color=locked and Theme.Accent or Theme.Stroke
            IStroke.Thickness=1; IStroke.Transparency=locked and 0.55 or 0.9; IStroke.Parent=ItemRow
            local NameLabel=Instance.new("TextLabel"); NameLabel.Size=UDim2.new(1,-42,1,0); NameLabel.Position=UDim2.new(0,11,0,0)
            NameLabel.BackgroundTransparency=1; NameLabel.Text=itemName
            NameLabel.TextColor3=locked and Theme.Accent or Theme.TextMain; NameLabel.Font=Enum.Font.GothamMedium
            NameLabel.TextSize=12; NameLabel.TextXAlignment=Enum.TextXAlignment.Left; NameLabel.ZIndex=26; NameLabel.Parent=ItemRow
            local CheckBox=Instance.new("TextButton"); CheckBox.Size=UDim2.new(0,22,0,22); CheckBox.Position=UDim2.new(1,-30,0.5,-11)
            CheckBox.BackgroundColor3=locked and Theme.Accent or Theme.ToggleOff
            CheckBox.Text=locked and "✓" or ""; CheckBox.TextColor3=Color3.fromRGB(8,8,12)
            CheckBox.Font=Enum.Font.GothamBlack; CheckBox.TextSize=12; CheckBox.AutoButtonColor=false; CheckBox.ZIndex=26; CheckBox.Parent=ItemRow
            Instance.new("UICorner",CheckBox).CornerRadius=UDim.new(0,5)
            CheckBox.MouseButton1Click:Connect(function()
                if Config.LockedItems[itemName] then
                    Config.LockedItems[itemName]=nil
                    TweenService:Create(CheckBox,TweenInfo.new(0.15),{BackgroundColor3=Theme.ToggleOff}):Play(); CheckBox.Text=""
                    TweenService:Create(ItemRow,TweenInfo.new(0.15),{BackgroundColor3=Theme.RowBg}):Play()
                    IStroke.Color=Theme.Stroke; NameLabel.TextColor3=Theme.TextMain
                else
                    Config.LockedItems[itemName]=true
                    TweenService:Create(CheckBox,TweenInfo.new(0.15),{BackgroundColor3=Theme.Accent}):Play(); CheckBox.Text="✓"
                    TweenService:Create(ItemRow,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(14,30,22)}):Play()
                    IStroke.Color=Theme.Accent; NameLabel.TextColor3=Theme.Accent
                end
            end)
        end
    end
    FilterList.CanvasSize=UDim2.new(0,0,0,FilterLayout.AbsoluteContentSize.Y)
end
RefreshFilterListRef=RefreshFilterList

local FltBtnHolder=Instance.new("Frame"); FltBtnHolder.Size=UDim2.new(1,-24,0,32); FltBtnHolder.Position=UDim2.new(0,12,1,-44)
FltBtnHolder.BackgroundTransparency=1; FltBtnHolder.ZIndex=22; FltBtnHolder.Parent=FilterFrame
