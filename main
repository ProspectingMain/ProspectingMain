-- SPOT PICKER
local function CreatePickSpotsUI()
    CreateSectionLabel("SPOT PICKER")
    local Holder=Instance.new("Frame"); Holder.Size=UDim2.new(1,0,0,36); Holder.BackgroundTransparency=1; Holder.Parent=Container
    local Layout=Instance.new("UIListLayout"); Layout.FillDirection=Enum.FillDirection.Horizontal; Layout.Padding=UDim.new(0,6); Layout.HorizontalAlignment=Enum.HorizontalAlignment.Left; Layout.Parent=Holder
    local function createSpotBtn(icon,label,saveMsg,configKey)
        local btn=Instance.new("TextButton"); btn.Size=UDim2.new(0.333,-5,1,0); btn.BackgroundColor3=Theme.Panel
        btn.TextColor3=Theme.TextDim; btn.Font=Enum.Font.GothamBold; btn.TextSize=11; btn.TextWrapped=true
        btn.Text=icon.."\n"..label; btn.LineHeight=1.2; btn.AutoButtonColor=false; btn.Parent=Holder
        Instance.new("UICorner",btn).CornerRadius=UDim.new(0,9)
        local bs=Instance.new("UIStroke"); bs.Color=Theme.Stroke; bs.Thickness=1; bs.Transparency=0.6; bs.Parent=btn
        btn.MouseEnter:Connect(function()
            TweenService:Create(bs,TweenInfo.new(0.15),{Color=Theme.Accent,Transparency=0.3}):Play()
            TweenService:Create(btn,TweenInfo.new(0.15),{TextColor3=Theme.Accent}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(bs,TweenInfo.new(0.15),{Color=Theme.Stroke,Transparency=0.6}):Play()
            TweenService:Create(btn,TweenInfo.new(0.15),{TextColor3=Theme.TextDim}):Play()
        end)
        btn.MouseButton1Click:Connect(function()
            local Char=LocalPlayer.Character; local Root=Char and Char:FindFirstChild("HumanoidRootPart")
            if Root then
                Config[configKey]=Root.Position; Config.StatusMessageOverride=saveMsg
                TweenService:Create(bs,TweenInfo.new(0.1),{Color=Theme.Accent,Transparency=0}):Play()
                task.delay(1.5,function() Config.StatusMessageOverride=nil; TweenService:Create(bs,TweenInfo.new(0.3),{Color=Theme.Stroke,Transparency=0.6}):Play() end)
            end
        end)
    end
    createSpotBtn("⛏","Sand Spot","Sand spot saved!","SandSpot")
    createSpotBtn("💧","Water Spot","Water spot saved!","WaterSpot")
    createSpotBtn("🗿","Totem Spot","Totem spot saved!","TotemSpot")
    CreateModernToggle("Auto Manual Walk","Walk between your picked Sand and Water spots (requires both spots set).",function(val)
        if val then
            if not (Config.SandSpot and Config.WaterSpot) then
                if ToggleUpdaters["Auto Manual Walk"] then ToggleUpdaters["Auto Manual Walk"](false) end
                Config.AutoManualWalk=false; Config.StatusMessageOverride="Pick both Sand & Water spots first!"
                task.delay(2,function() Config.StatusMessageOverride=nil end); return
            end
            Config.AutoManualWalk=true
        else
            Config.AutoManualWalk=false
        end
    end)
end
