local function createCard(parent, yPos, height, zBase)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1,-40,0,height); card.Position = UDim2.new(0,20,0,yPos)
    card.BackgroundColor3 = Theme.KeybindBg; card.ZIndex = zBase; card.Parent = parent
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
    local cs = Instance.new("UIStroke"); cs.Color = Theme.Stroke; cs.Thickness = 1; cs.Transparency = 0.5; cs.Parent = card
    return card
end

local function createCardTitle(parent, text, zBase)
