NextBtn.MouseLeave:Connect(function() TweenService:Create(NextBtn,TweenInfo.new(0.15),{BackgroundColor3=Theme.Accent}):Play() end)
PrevBtn.MouseEnter:Connect(function()
    TweenService:Create(PrevStroke,TweenInfo.new(0.15),{Color=Theme.Accent,Transparency=0.3}):Play()
    TweenService:Create(PrevBtn,TweenInfo.new(0.15),{TextColor3=Theme.Accent}):Play()
end)
