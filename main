local function createKeyRow(parent, keyLabel, descText, yPos, zBase)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -24, 0, 30); row.Position = UDim2.new(0, 12, 0, yPos)
    row.BackgroundTransparency = 1; row.ZIndex = zBase; row.Parent = parent
    local badge = Instance.new("Frame")
    badge.Size = UDim2.new(0, 36, 0, 26); badge.Position = UDim2.new(0, 0, 0.5, -13)
    badge.BackgroundColor3 = Color3.fromRGB(18, 18, 30); badge.ZIndex = zBase; badge.Parent = row
    Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 6)
    local bs = Instance.new("UIStroke"); bs.Color = Theme.Accent; bs.Thickness = 1; bs.Transparency = 0.45; bs.Parent = badge
    local kLbl = Instance.new("TextLabel")
    kLbl.Size = UDim2.new(1,0,1,0); kLbl.BackgroundTransparency = 1; kLbl.Text = keyLabel
    kLbl.TextColor3 = Theme.Accent; kLbl.Font = Enum.Font.GothamBold; kLbl.TextSize = 12
    kLbl.ZIndex = zBase+1; kLbl.Parent = badge
    local dLbl = Instance.new("TextLabel")
    dLbl.Size = UDim2.new(1,-48,1,0); dLbl.Position = UDim2.new(0,48,0,0); dLbl.BackgroundTransparency = 1
    dLbl.Text = descText; dLbl.TextColor3 = Theme.TextMain; dLbl.Font = Enum.Font.GothamMedium
    dLbl.TextSize = 12; dLbl.TextXAlignment = Enum.TextXAlignment.Left; dLbl.ZIndex = zBase+1; dLbl.Parent = row
end

