    TweenService:Create(PrevStroke,TweenInfo.new(0.15),{Color=Theme.Stroke,Transparency=0}):Play()
    TweenService:Create(PrevBtn,TweenInfo.new(0.15),{TextColor3=Theme.TextDim}):Play()
end)

PrevBtn.MouseButton1Click:Connect(function()
    if currentPage > 1 then
        goToPage(currentPage - 1)
        PrevBtn.Visible = currentPage > 1
        NextBtn.Text    = currentPage == TOTAL_PAGES and "Start Farming  ✓" or "Next  →"
    end
end)

NextBtn.MouseButton1Click:Connect(function()
    if currentPage < TOTAL_PAGES then
        goToPage(currentPage + 1)
        PrevBtn.Visible = true
        NextBtn.Text    = currentPage == TOTAL_PAGES and "Start Farming  ✓" or "Next  →"
    else
        TweenService:Create(WarningDimmer,TweenInfo.new(0.5),{BackgroundTransparency=1}):Play()
        TweenService:Create(WarningFrame,TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size=UDim2.new(0,0,0,0)}):Play()
        task.wait(0.4)
        WarningDimmer.Visible = false
        WarningFrame.Visible  = false
        local MF = ScreenGui:FindFirstChild("MainFrame")
        if MF then
            MF.Visible = true
            MF.Size    = UDim2.new(0,0,0,0)
            TweenService:Create(MF,TweenInfo.new(0.45,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,360,0,550)}):Play()
        end
    end
end)

-- Show setup guide immediately on load
task.spawn(function()
    task.wait(0.3)
    local MF = ScreenGui:FindFirstChild("MainFrame")
    if MF then MF.Visible = true end
    TweenService:Create(WarningDimmer,TweenInfo.new(0.5),{BackgroundTransparency=0.25}):Play()
    TweenService:Create(WarningFrame,TweenInfo.new(0.55,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,420,0,400)}):Play()
end)

