-- Navigation
local currentPage = 1
local TOTAL_PAGES = 3
local pages = {Page1, Page2, Page3}

local function goToPage(n)
    for i, pg in ipairs(pages) do pg.Visible = (i == n) end
    for i, dot in ipairs(pageDots) do
        TweenService:Create(dot, TweenInfo.new(0.2), {BackgroundColor3 = i==n and Theme.Accent or Color3.fromRGB(38,38,55)}):Play()
    end
    currentPage = n
end

