local function CreateModernToggle(text,infoText,callback)
    local Frame=Instance.new("Frame"); Frame.Size=UDim2.new(1,0,0,46); Frame.BackgroundColor3=Theme.Panel; Frame.Parent=Container
    Instance.new("UICorner",Frame).CornerRadius=UDim.new(0,10)
    local FrameStroke=Instance.new("UIStroke"); FrameStroke.Color=Theme.Stroke; FrameStroke.Thickness=1; FrameStroke.Transparency=0.7; FrameStroke.Parent=Frame
    local Label=Instance.new("TextLabel"); Label.Size=UDim2.new(0.62,0,1,0); Label.Position=UDim2.new(0,14,0,0)
    Label.BackgroundTransparency=1; Label.Text=text; Label.TextColor3=Theme.TextMain; Label.Font=Enum.Font.GothamMedium; Label.TextSize=13
    Label.TextXAlignment=Enum.TextXAlignment.Left; Label.Parent=Frame
    local InfoBtn=Instance.new("TextButton"); InfoBtn.Size=UDim2.new(0,16,0,16); InfoBtn.Position=UDim2.new(0,14,0.5,-8)
    InfoBtn.BackgroundColor3=Color3.fromRGB(28,28,44); InfoBtn.Text="?"; InfoBtn.TextColor3=Theme.TextDim
    InfoBtn.Font=Enum.Font.GothamBold; InfoBtn.TextSize=10; InfoBtn.AutoButtonColor=false; InfoBtn.ZIndex=2; InfoBtn.Parent=Frame
    Instance.new("UICorner",InfoBtn).CornerRadius=UDim.new(1,0)
    task.spawn(function()
        task.wait()
        local bounds=game:GetService("TextService"):GetTextSize(text,13,Enum.Font.GothamMedium,Vector2.new(200,50))
        InfoBtn.Position=UDim2.new(0,14+bounds.X+7,0.5,-8)
    end)
    InfoBtn.MouseEnter:Connect(function() local p=InfoBtn.AbsolutePosition; ShowTooltip(infoText,p.X,p.Y+22) end)
    InfoBtn.MouseLeave:Connect(function() HideTooltip() end)
    local Switch=Instance.new("Frame"); Switch.Size=UDim2.new(0,44,0,22); Switch.Position=UDim2.new(1,-56,0.5,-11)
    Switch.BackgroundColor3=Theme.ToggleOff; Switch.Parent=Frame
    Instance.new("UICorner",Switch).CornerRadius=UDim.new(1,0)
    local SwitchStroke=Instance.new("UIStroke"); SwitchStroke.Color=Theme.Stroke; SwitchStroke.Thickness=1; SwitchStroke.Transparency=0.5; SwitchStroke.Parent=Switch
    local Knob=Instance.new("Frame"); Knob.Size=UDim2.new(0,16,0,16); Knob.Position=UDim2.new(0,3,0.5,-8)
    Knob.BackgroundColor3=Theme.TextDim; Knob.ZIndex=2; Knob.Parent=Switch
    Instance.new("UICorner",Knob).CornerRadius=UDim.new(1,0)
    local Button=Instance.new("TextButton"); Button.Size=UDim2.new(1,0,1,0); Button.BackgroundTransparency=1; Button.Text=""; Button.ZIndex=3; Button.Parent=Switch
    local isOn=false
    local function SetState(state)
        isOn=state
        if isOn then
            TweenService:Create(Switch,TweenInfo.new(0.22,Enum.EasingStyle.Quad),{BackgroundColor3=Theme.Accent}):Play()
            TweenService:Create(Knob,TweenInfo.new(0.22,Enum.EasingStyle.Quad),{Position=UDim2.new(1,-19,0.5,-8),BackgroundColor3=Color3.fromRGB(8,8,12)}):Play()
            TweenService:Create(FrameStroke,TweenInfo.new(0.22),{Color=Color3.fromRGB(0,100,70),Transparency=0.3}):Play()
        else
            TweenService:Create(Switch,TweenInfo.new(0.22,Enum.EasingStyle.Quad),{BackgroundColor3=Theme.ToggleOff}):Play()
            TweenService:Create(Knob,TweenInfo.new(0.22,Enum.EasingStyle.Quad),{Position=UDim2.new(0,3,0.5,-8),BackgroundColor3=Theme.TextDim}):Play()
            TweenService:Create(FrameStroke,TweenInfo.new(0.22),{Color=Theme.Stroke,Transparency=0.7}):Play()
        end
        callback(isOn)
    end
    ToggleUpdaters[text]=SetState
    Button.MouseButton1Click:Connect(function() SetState(not isOn) end)
end

local function CreateActionButtons()
    local Holder=Instance.new("Frame"); Holder.Size=UDim2.new(1,0,0,36); Holder.BackgroundTransparency=1; Holder.Parent=Container
    local Layout=Instance.new("UIListLayout"); Layout.FillDirection=Enum.FillDirection.Horizontal; Layout.Padding=UDim.new(0,8); Layout.Parent=Holder
    local function makeActionBtn(txt,tc,bg,strokeC,onClick)
        local b=Instance.new("TextButton"); b.Size=UDim2.new(0.5,-4,1,0); b.BackgroundColor3=bg; b.Text=txt; b.TextColor3=tc
        b.Font=Enum.Font.GothamBold; b.TextSize=13; b.AutoButtonColor=false; b.Parent=Holder
        Instance.new("UICorner",b).CornerRadius=UDim.new(0,9)
        local s=Instance.new("UIStroke"); s.Color=strokeC; s.Thickness=1; s.Transparency=0.55; s.Parent=b
        b.MouseEnter:Connect(function() TweenService:Create(s,TweenInfo.new(0.15),{Transparency=0.1}):Play() end)
        b.MouseLeave:Connect(function() TweenService:Create(s,TweenInfo.new(0.15),{Transparency=0.55}):Play() end)
        b.MouseButton1Click:Connect(onClick); return b
    end
    makeActionBtn("🔒  Auto Lock",Theme.Accent,Color3.fromRGB(10,24,18),Theme.Accent,function()
        RefreshFilterList(""); FilterFrame.Visible=true
    end)
    makeActionBtn("⚙  Configs",Color3.fromRGB(255,195,80),Color3.fromRGB(26,22,10),Color3.fromRGB(180,130,30),function()
        RefreshConfigs(); ConfigFrame.Visible=true
    end)
end

-- // 5. GAME FUNCTIONS //
local function GetEquippedPan()
    local Char=LocalPlayer.Character; if not Char then return nil end
    local tool=Char:FindFirstChildOfClass("Tool"); if not tool then return nil end
    local knownPans={["Metal Pan"]=true,["Silver Pan"]=true,["Golden Pan"]=true,["Diamond Pan"]=true,["Aurora Pan"]=true,["Magnetic Pan"]=true,["Dragonflame Pan"]=true,["Abyssal Pan"]=true,["Blightflow Pan"]=true,["Fossilized Pan"]=true}
    if knownPans[tool.Name] and tool:FindFirstChild("Scripts") then return tool end
    if not PansFolder then PansFolder=ReplicatedStorage:FindFirstChild("Items") and ReplicatedStorage.Items:FindFirstChild("Pans") end
    if PansFolder and PansFolder:FindFirstChild(tool.Name) and tool:FindFirstChild("Scripts") then return tool end
    if tool:FindFirstChild("Scripts") then
        local s=tool.Scripts
        if s:FindFirstChild("Pan") or s:FindFirstChild("Shake") or s:FindFirstChild("Collect") then return tool end
    end
    return nil
end

local function GetInventoryStatus()
    local max=LocalPlayer:GetAttribute("InventorySize") or 500; local current=0
    local backpack=LocalPlayer:FindFirstChild("BackpackTwo") or LocalPlayer:FindFirstChild("Backpack")
    local itemsToCheck={}
    if backpack then for _,v in pairs(backpack:GetChildren()) do table.insert(itemsToCheck,v) end end
    if LocalPlayer.Character then for _,v in pairs(LocalPlayer.Character:GetChildren()) do if v:IsA("Tool") then table.insert(itemsToCheck,v) end end end
    for _,item in pairs(itemsToCheck) do
        local iType=item:GetAttribute("ItemType")
        if iType=="Equipment" or iType=="Valuable" then current=current+1 end
    end
    return current, max
end

local function GetFillAmount(tool)
    if tool then local a=tool:GetAttribute("Fill"); if a then return a end end
    local Stats=LocalPlayer:FindFirstChild("Stats")
    if Stats then
        local s=Stats:GetAttribute("Sand") or Stats:GetAttribute("Fill"); if s then return s end
        if Stats:FindFirstChild("Sand") then return Stats.Sand.Value end
    end
    return 0
end

local function GetCapacity(tool)
    local Stats=LocalPlayer:FindFirstChild("Stats")
    if Stats then local c=Stats:GetAttribute("Capacity"); if c then return c end end
    return 100
end

local function GetStateLabel()
    local pGui=LocalPlayer:FindFirstChild("PlayerGui"); if pGui then
        local toolUI=pGui:FindFirstChild("ToolUI"); if toolUI then
            local controls=toolUI:FindFirstChild("Controls"); if controls then
                local label=controls:FindFirstChildOfClass("TextLabel"); if label then return label.Text end
            end
        end
    end
    return "Unknown"
end

local function IsShakingActionActive()
    if not Config.AutoShake then return false end
    if Config.IsPanning then return true end
    local PanTool=GetEquippedPan()
    if PanTool then
        local fill=GetFillAmount(PanTool); local state=GetStateLabel()
        if fill>0 and state=="Pan" then return true end
    end
    return false
end

-- // 6. PATHFINDING & MOVEMENT //
local function GetNearestMerchant()
    local Char=LocalPlayer.Character; if not Char then return nil end
    local Root=Char:FindFirstChild("HumanoidRootPart"); if not Root then return nil end
    local closestDist=math.huge; local closestPos=nil
    local validNames={Merchant=true,["Shady Merchant"]=true,Seller=true,Trader=true,["Traveling Merchant"]=true,["Shard Merchant"]=true,["Timelocked Merchant"]=true}
    local function ScanFolder(folder)
        for _,obj in pairs(folder:GetDescendants()) do
            if obj:IsA("Model") and validNames[obj.Name] then
                local hrp=obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso") or obj.PrimaryPart
                if hrp then
                    local dist=(Root.Position-hrp.Position).Magnitude
                    if dist<closestDist then closestDist=dist; closestPos=hrp.Position end
                end
            end
        end
    end
    if workspace:FindFirstChild("NPCs") then ScanFolder(workspace.NPCs) end
    if not closestPos then ScanFolder(workspace) end
    return closestPos
end

local function CheckObstacle(Root)
    local params=RaycastParams.new(); params.FilterDescendantsInstances={LocalPlayer.Character}; params.FilterType=Enum.RaycastFilterType.Exclude
    local forward=Root.CFrame.LookVector; local pos=Root.Position
    local kneePos=pos-Vector3.new(0,2.5,0); local kneeRay=workspace:Raycast(kneePos,forward*6,params)
    local chestRay=workspace:Raycast(pos,forward*6,params)
    if kneeRay and kneeRay.Instance.CanCollide then return "Jump"
    elseif chestRay and chestRay.Instance.CanCollide then return "Blocked" end
    return nil
end

local function SmartWalkTo(destination,stopCondition)
    local Char=LocalPlayer.Character; if not Char then return end
    local Humanoid=Char:FindFirstChild("Humanoid"); local Root=Char:FindFirstChild("HumanoidRootPart")
    if not Humanoid or not Root then return end
    if (Root.Position-destination).Magnitude<5 then Humanoid:MoveTo(destination); task.wait(0.5); return end
    local path=PathfindingService:CreatePath({AgentRadius=3,AgentHeight=5,AgentCanJump=true,WaypointSpacing=3,Costs={Water=20,Rock=5,Slate=5,Basalt=5}})
    local success,_=pcall(function() path:ComputeAsync(Root.Position,destination) end)
    if success and path.Status==Enum.PathStatus.Success then
        local waypoints=path:GetWaypoints(); local lastPosition=Root.Position
        local stuckCount=0; local stuckFrames=0; local lastJumpTime=0
        for i,waypoint in ipairs(waypoints) do
            if not _G.SigmaFarm_Running then return end
            if stopCondition and stopCondition() then Humanoid:MoveTo(Root.Position); return end
            if waypoint.Action==Enum.PathWaypointAction.Jump then Humanoid.Jump=true end
            Humanoid:MoveTo(waypoint.Position)
            local timeout=tick()+5; local distanceThreshold=(i==#waypoints) and 3 or 4
            local stuckCheckTime=tick()
            while (Root.Position-waypoint.Position).Magnitude>distanceThreshold and tick()<timeout do
                if stopCondition and stopCondition() then Humanoid:MoveTo(Root.Position); return end
                if tick()-stuckCheckTime>0.15 then
                    if (Root.Position-lastPosition).Magnitude<0.1 then stuckCount=stuckCount+1 else stuckCount=0; lastPosition=Root.Position end
                    stuckCheckTime=tick()
                end
                local currentVel=Root.AssemblyLinearVelocity*Vector3.new(1,0,1)
                if currentVel.Magnitude<2 then stuckFrames=stuckFrames+1 else stuckFrames=0 end
                local obsType=CheckObstacle(Root)
                if (obsType=="Jump" or obsType=="Blocked" or stuckFrames>8) and (tick()-lastJumpTime>0.5) then
                    Humanoid.Jump=true; lastJumpTime=tick(); stuckFrames=0
                    local dir=(waypoint.Position-Root.Position).Unit
                    Humanoid:MoveTo(waypoint.Position+(dir*8)); task.wait(0.2); Humanoid:MoveTo(waypoint.Position)
                end
                if stuckCount>=5 then
                    Humanoid.Jump=true; Humanoid:MoveTo(waypoint.Position); task.wait(0.2)
                    if (Root.Position-lastPosition).Magnitude<0.1 then
                        Humanoid:MoveTo(Root.Position+Vector3.new(math.random(-2,2),0,math.random(-2,2))); task.wait(0.2)
                    end
                    stuckCount=0
                end
                task.wait(0.05)
            end
        end
    else
        Humanoid:MoveTo(destination)
        local timeout=tick()+10; local lastPos=Root.Position; local stuckCheckTime=tick(); local stuckCount=0; local stuckFrames=0; local lastJumpTime=0
        while (Root.Position-destination).Magnitude>5 and tick()<timeout do
            if stopCondition and stopCondition() then Humanoid:MoveTo(Root.Position); return end
            if tick()-stuckCheckTime>0.15 then
                if (Root.Position-lastPos).Magnitude<0.1 then stuckCount=stuckCount+1 else stuckCount=0; lastPos=Root.Position end
                stuckCheckTime=tick()
            end
            local currentVel=Root.AssemblyLinearVelocity*Vector3.new(1,0,1)
            if currentVel.Magnitude<2 then stuckFrames=stuckFrames+1 else stuckFrames=0 end
            local obsType=CheckObstacle(Root)
            if (obsType=="Jump" or obsType=="Blocked" or stuckFrames>8) and (tick()-lastJumpTime>0.5) then
                Humanoid.Jump=true; lastJumpTime=tick(); stuckFrames=0
            end
            if stuckCount>=5 then Humanoid.Jump=true; Humanoid:MoveTo(destination); task.wait(0.2); stuckCount=0 end
            task.wait(0.1)
        end
    end
end

local function SimpleWalkTo(position)
    local Char=LocalPlayer.Character; if not Char then return end
    local Hum=Char:FindFirstChild("Humanoid"); if not Hum then return end
    if Hum.Sit then Hum.Sit=false end
    Hum:MoveTo(position)
end

-- // 7. TOTEM & SURFACE LOGIC //
local function GetTotemRadiusAndCenter(totemModel)
    local mainPart=totemModel:FindFirstChild("MainPart"); if not mainPart then return nil end
    local maxRadius=0
    for i=1,4 do
        local att=mainPart:FindFirstChild(tostring(i))
        if att and att:IsA("Attachment") then
            local r=(att.WorldPosition-mainPart.Position).Magnitude
            if r>maxRadius then maxRadius=r end
        end
    end
    if maxRadius<=0 then maxRadius=6 end
    return maxRadius, mainPart.Position, mainPart
end

local function IsInTotemRadius(pos,totemModel)
    local radius,center=GetTotemRadiusAndCenter(totemModel)
    if not radius or not center then return false end
    return (pos-center).Magnitude<=radius
end

local function GetNearbyTotems(playerPos,maxSearchDistance)
    maxSearchDistance=maxSearchDistance or 80; local nearby={}
    local activeTotems=workspace:FindFirstChild("ActiveTotems"); if not activeTotems then return nearby end
    for _,totem in pairs(activeTotems:GetChildren()) do
        if totem:IsA("Model") then
            local name=totem.Name
            if name:find("Luck") or name:find("Strength") or name:find("Luminant") then
                local mainPart=totem:FindFirstChild("MainPart")
                if mainPart and (playerPos-mainPart.Position).Magnitude<maxSearchDistance then
                    table.insert(nearby,totem)
                end
            end
        end
    end
    return nearby
end

local function CheckRegion(position)
    if PointToRegion then
        local regionName,_=PointToRegion.GetPanningRegion(position)
        if regionName=="Water" then return "Water" end
        if regionName=="Deposit" then return "Deposit" end
        return nil
    end
    local region=Region3.new(position-Vector3.new(2,2,2),position+Vector3.new(2,2,2))
    local success,material,_=pcall(function() return workspace.Terrain:ReadVoxels(region,4) end)
    if success and material then
        local mat=material[1][1][1]
        if mat==Enum.Material.Water then return "Water"
        elseif mat~=Enum.Material.Air and mat~=Enum.Material.Water then return "Deposit" end
    end
    return nil
end

local function GetSurfaceData(x,z)
    local Char=LocalPlayer.Character; if not Char then return nil,nil end
    local Root=Char:FindFirstChild("HumanoidRootPart"); if not Root then return nil,nil end
    local origin=Root.Position+Vector3.new(x,10,z)
    local params=RaycastParams.new(); params.FilterDescendantsInstances={Char}; params.FilterType=Enum.RaycastFilterType.Exclude; params.IgnoreWater=false
    local result=workspace:Raycast(origin,Vector3.new(0,-60,0),params)
    if result then return result.Position, result.Material end
    return nil,nil
end

local function GetTotemContainingPosition(pos)
    local activeTotems=workspace:FindFirstChild("ActiveTotems"); if not activeTotems then return nil end
    for _,totem in pairs(activeTotems:GetChildren()) do
        if totem:IsA("Model") and IsInTotemRadius(pos,totem) then return totem end
    end
    return nil
end

local function GetSpecificTotem(pos,totemType)
    local activeTotems=workspace:FindFirstChild("ActiveTotems"); if not activeTotems then return nil end
    for _,totem in pairs(activeTotems:GetChildren()) do
        if totem:IsA("Model") and totem.Name:find(totemType) and IsInTotemRadius(pos,totem) then return totem end
    end
    return nil
end

local function FindNearestTarget(targetType)
    local Char=LocalPlayer.Character; if not Char then return nil end
    local Root=Char:FindFirstChild("HumanoidRootPart"); if not Root then return nil end
    local center=Root.Position
    local currentTotem=GetTotemContainingPosition(center); local nearbyTotems=GetNearbyTotems(center,80)
    local bestPos=nil; local bestDist=9999; local bestTotemPos=nil; local bestTotemDist=9999
    for x=-30,30,6 do for z=-30,30,6 do
        local surfPos,surfMat=GetSurfaceData(x,z)
        if surfPos then
            local physicallyValid=false
            if targetType=="Water" and surfMat==Enum.Material.Water then physicallyValid=true
            elseif targetType=="Deposit" and surfMat~=Enum.Material.Water and surfMat~=Enum.Material.Air then physicallyValid=true end
            if physicallyValid then
                local regionType=CheckRegion(surfPos)
                if not regionType and targetType=="Water" and surfMat==Enum.Material.Water then regionType="Water" end
                if regionType==targetType then
                    local dist=(center-surfPos).Magnitude
                    if currentTotem then
                        if IsInTotemRadius(surfPos,currentTotem) and dist<bestTotemDist then bestTotemDist=dist; bestTotemPos=surfPos end
                    else
                        local isInsideAnyTotem=false
                        for _,totem in pairs(nearbyTotems) do if IsInTotemRadius(surfPos,totem) then isInsideAnyTotem=true; break end end
                        if isInsideAnyTotem then
                            if dist<bestTotemDist then bestTotemDist=dist; bestTotemPos=surfPos end
                        elseif dist<bestDist then bestDist=dist; bestPos=surfPos end
                    end
                end
            end
        end
    end end
    if currentTotem and not bestTotemPos then
        local radius,centerPos=GetTotemRadiusAndCenter(currentTotem)
        if radius and centerPos then
            local dir=(center-centerPos)
            local fallback=dir.Magnitude>1 and centerPos+dir.Unit*math.max(radius*0.75,2) or centerPos+Vector3.new(0,0,math.min(radius*0.75,2))
            return fallback
        end
    end
    return bestTotemPos or bestPos
end

