local function addVersionBlock(version, date, isLatest, entries, layoutOrder)
    local blockHeight = 22 + 6 + (#entries * 34) + 20
    local block=Instance.new("Frame"); block.Size=UDim2.new(1,0,0,blockHeight)
    block.BackgroundColor3=Color3.fromRGB(14,14,22); block.ZIndex=803; block.LayoutOrder=layoutOrder; block.Parent=CLScroll
    Instance.new("UICorner",block).CornerRadius=UDim.new(0,10)
    local bStroke=Instance.new("UIStroke"); bStroke.Color=isLatest and Theme.Accent or Theme.Stroke
    bStroke.Thickness=1; bStroke.Transparency=isLatest and 0.3 or 0.75; bStroke.Parent=block
    local innerPad=Instance.new("UIPadding"); innerPad.PaddingLeft=UDim.new(0,12); innerPad.PaddingRight=UDim.new(0,12)
    innerPad.PaddingTop=UDim.new(0,10); innerPad.PaddingBottom=UDim.new(0,10); innerPad.Parent=block
    local innerLayout=Instance.new("UIListLayout"); innerLayout.SortOrder=Enum.SortOrder.LayoutOrder; innerLayout.Padding=UDim.new(0,4); innerLayout.Parent=block
    local headerRow=Instance.new("Frame"); headerRow.Size=UDim2.new(1,0,0,22); headerRow.BackgroundTransparency=1; headerRow.LayoutOrder=0; headerRow.ZIndex=804; headerRow.Parent=block
    local verLbl=Instance.new("TextLabel"); verLbl.Size=UDim2.new(0.6,0,1,0); verLbl.BackgroundTransparency=1; verLbl.Text=version
    verLbl.TextColor3=isLatest and Theme.Accent or Theme.TextMain; verLbl.Font=Enum.Font.GothamBlack; verLbl.TextSize=13
    verLbl.TextXAlignment=Enum.TextXAlignment.Left; verLbl.ZIndex=804; verLbl.Parent=headerRow
    if isLatest then
        local nb=Instance.new("TextLabel"); nb.Size=UDim2.new(0,44,0,16); nb.Position=UDim2.new(0,110,0.5,-8)
        nb.BackgroundColor3=Color3.fromRGB(0,60,40); nb.Text="LATEST"; nb.TextColor3=Theme.Accent
        nb.Font=Enum.Font.GothamBold; nb.TextSize=9; nb.ZIndex=805; nb.Parent=headerRow
        Instance.new("UICorner",nb).CornerRadius=UDim.new(0,4)
    end
    local dateLbl=Instance.new("TextLabel"); dateLbl.Size=UDim2.new(0.4,0,1,0); dateLbl.Position=UDim2.new(0.6,0,0,0)
    dateLbl.BackgroundTransparency=1; dateLbl.Text=date; dateLbl.TextColor3=Theme.TextDim; dateLbl.Font=Enum.Font.Gotham
    dateLbl.TextSize=10; dateLbl.TextXAlignment=Enum.TextXAlignment.Right; dateLbl.ZIndex=804; dateLbl.Parent=headerRow
    local div=Instance.new("Frame"); div.Size=UDim2.new(1,0,0,1); div.BackgroundColor3=isLatest and Theme.Accent or Theme.Stroke
    div.BackgroundTransparency=isLatest and 0.6 or 0.8; div.BorderSizePixel=0; div.LayoutOrder=1; div.ZIndex=803; div.Parent=block
    local tagColors={["NEW"]=Color3.fromRGB(0,200,130),["FIX"]=Color3.fromRGB(255,160,50),["REMOVED"]=Color3.fromRGB(255,70,80),["IMPROVED"]=Color3.fromRGB(100,180,255),["INFO"]=Color3.fromRGB(160,160,190)}
    for i, entry in ipairs(entries) do
        local tag,text=entry[1],entry[2]
        local row=Instance.new("Frame"); row.Size=UDim2.new(1,0,0,30); row.BackgroundTransparency=1; row.LayoutOrder=i+1; row.ZIndex=804; row.Parent=block
        local tl=Instance.new("TextLabel"); tl.Size=UDim2.new(0,66,0,18); tl.BackgroundColor3=Color3.fromRGB(16,16,26)
        tl.Text=tag; tl.TextColor3=tagColors[tag] or Theme.TextDim; tl.Font=Enum.Font.GothamBold; tl.TextSize=9; tl.ZIndex=805; tl.Parent=row
        Instance.new("UICorner",tl).CornerRadius=UDim.new(0,4)
        local el=Instance.new("TextLabel"); el.Size=UDim2.new(1,-76,0,28); el.Position=UDim2.new(0,74,0,1)
        el.BackgroundTransparency=1; el.Text=text; el.TextColor3=Theme.TextDim; el.Font=Enum.Font.Gotham; el.TextSize=11
        el.TextWrapped=true; el.TextXAlignment=Enum.TextXAlignment.Left; el.TextYAlignment=Enum.TextYAlignment.Top; el.ZIndex=804; el.Parent=row
    end
end

