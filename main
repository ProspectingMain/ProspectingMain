local ToggleUpdaters    = {}
local RefreshFilterListRef = nil

-- // 3. CONFIG FUNCTIONS //
local function SaveConfig(name)
    if not name or name == "" then return end
    local data = {
        AutoShovel  = Config.AutoShovel,
        AutoShake   = Config.AutoShake,
        AutoSell    = Config.AutoSell,
        AutoGeode   = Config.AutoGeode,
        AutoTotem   = Config.AutoTotem,
        LockedItems = Config.LockedItems
    }
    pcall(function()
        writefile(FolderName .. "/" .. name .. ".json", HttpService:JSONEncode(data))
    end)
end

local function LoadConfig(name)
    local ok, content = pcall(readfile, FolderName .. "/" .. name .. ".json")
    if not ok or not content then warn("Config file not found:", name) return end
    local dok, data = pcall(HttpService.JSONDecode, HttpService, content)
    if not dok or not data then warn("Failed to parse config:", name) return end

    Config.AutoShovel  = data.AutoShovel  or false
    Config.AutoShake   = data.AutoShake   or false
    Config.AutoSell    = data.AutoSell    or false
    Config.AutoGeode   = data.AutoGeode   or false
    Config.AutoTotem   = data.AutoTotem   or false
    Config.LockedItems = data.LockedItems or {}

    if ToggleUpdaters["Auto Shovel"]         then ToggleUpdaters["Auto Shovel"](Config.AutoShovel) end
    if ToggleUpdaters["Auto Pan & Shake"]    then ToggleUpdaters["Auto Pan & Shake"](Config.AutoShake) end
    if ToggleUpdaters["Auto Sell"]           then ToggleUpdaters["Auto Sell"](Config.AutoSell) end
    if ToggleUpdaters["Auto Collect Geodes"] then ToggleUpdaters["Auto Collect Geodes"](Config.AutoGeode) end
    if ToggleUpdaters["Auto Place Totem"]    then ToggleUpdaters["Auto Place Totem"](Config.AutoTotem) end

    if RefreshFilterListRef then RefreshFilterListRef("") end
end

local function SetAutoload(name)    pcall(writefile, FolderName .. "/autoload.txt", name) end
local function ClearAutoload()
    pcall(function()
        if isfile(FolderName .. "/autoload.txt") then delfile(FolderName .. "/autoload.txt") end
    end)
end
local function GetAutoload()
    local ok, content = pcall(readfile, FolderName .. "/autoload.txt")
    if ok and content then return content:match("[^/\\]+$") or content end
    return nil
end
local function DeleteConfig(name)
    pcall(function()
        if isfile(FolderName .. "/" .. name .. ".json") then delfile(FolderName .. "/" .. name .. ".json") end
    end)
end
local function GetConfigList()
    local ok, files = pcall(listfiles, FolderName)
    if not ok or not files then return {} end
    local names = {}
    for _, file in pairs(files) do
        if file:sub(-5) == ".json" then
            local n = (file:match("[^/\\]+$") or file):gsub("%.json$","")
            table.insert(names, n)
        end
    end
    return names
end

