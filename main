-- // GEODE LOOP //
task.spawn(function()
    while _G.SigmaFarm_Running do
        task.wait(1)
        if Config.AutoGeode and not Config.IsSelling and not Config.IsGeodeCollecting and not Config.IsPlacingTotem and not IsShakingActionActive() then
            local GeodeFolder=workspace:FindFirstChild("Geode")
            if GeodeFolder then
                local targets={}; for _,v in pairs(GeodeFolder:GetChildren()) do if v:IsA("Model") then table.insert(targets,v) end end
                if #targets>0 then
                    Config.IsGeodeCollecting=true
                    local Char=LocalPlayer.Character; local Root=Char and Char:FindFirstChild("HumanoidRootPart")
                    if Root then
                        if not GeodeOriginCFrame then GeodeOriginCFrame=Root.CFrame end
                        for _,geode in pairs(targets) do
                            if not Config.AutoGeode or not _G.SigmaFarm_Running then break end
                            if geode and geode.Parent then
                                Root.CFrame=geode.PrimaryPart and geode.PrimaryPart.CFrame or geode:GetPivot(); task.wait(0.8)
                            end
                        end
                        if Config.AutoGeode and _G.SigmaFarm_Running then Root.CFrame=GeodeOriginCFrame; GeodeOriginCFrame=nil end
                    end
                    Config.IsGeodeCollecting=false
                end
            end
        end
    end
end)

-- // TOTEM LOOP //
local TotemPlaceCooldown={Luck=0,Strength=0,Luminant=0}
local SlotKeys={[1]=Enum.KeyCode.One,[2]=Enum.KeyCode.Two,[3]=Enum.KeyCode.Three,[4]=Enum.KeyCode.Four,[5]=Enum.KeyCode.Five,[6]=Enum.KeyCode.Six,[7]=Enum.KeyCode.Seven,[8]=Enum.KeyCode.Eight,[9]=Enum.KeyCode.Nine}

local KnownPans={["Metal Pan"]=true,["Silver Pan"]=true,["Golden Pan"]=true,["Diamond Pan"]=true,["Aurora Pan"]=true,["Magnetic Pan"]=true,["Dragonflame Pan"]=true,["Abyssal Pan"]=true,["Blightflow Pan"]=true,["Fossilized Pan"]=true}
local function IsPanTool(tool)
    if not tool or not tool:IsA("Tool") then return false end
    if KnownPans[tool.Name] then return true end
    local scripts=tool:FindFirstChild("Scripts")
    if scripts and (scripts:FindFirstChild("Pan") or scripts:FindFirstChild("Shake") or scripts:FindFirstChild("Collect")) then return true end
    return false
end
local function GetBackpack() return LocalPlayer:FindFirstChild("BackpackTwo") or LocalPlayer:FindFirstChild("Backpack") end
local function FindPanAnywhere(savedPanName)
    local Char=LocalPlayer.Character; local backpack=GetBackpack()
    if savedPanName then
        if Char then local t=Char:FindFirstChild(savedPanName); if t and t:IsA("Tool") then return t end end
        if backpack then local t=backpack:FindFirstChild(savedPanName); if t and t:IsA("Tool") then return t end end
    end
    if Char then for _,t in pairs(Char:GetChildren()) do if IsPanTool(t) then return t end end end
    if backpack then for _,t in pairs(backpack:GetChildren()) do if IsPanTool(t) then return t end end end
    return nil
end
local function FindToolByName(partialName)
    local Char=LocalPlayer.Character; local backpack=GetBackpack()
    if Char then for _,t in pairs(Char:GetChildren()) do if t:IsA("Tool") and t.Name:find(partialName) then return t end end end
    if backpack then for _,t in pairs(backpack:GetChildren()) do if t:IsA("Tool") and t.Name:find(partialName) then return t end end end
    return nil
end
local function GetToolHotkey(tool)
    local slot=tool:GetAttribute("NewHotbarSlot")
    if slot and SlotKeys[slot] then return SlotKeys[slot] end
    local backpack=GetBackpack()
    if backpack then local idx=1; for _,t in pairs(backpack:GetChildren()) do if t:IsA("Tool") then if t==tool and SlotKeys[idx] then return SlotKeys[idx] end; idx=idx+1 end end end
    return nil
end
local function PressHotkey(keyCode)
    VirtualInputManager:SendKeyEvent(true,keyCode,false,game); task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false,keyCode,false,game); task.wait(0.15)
end
local function GetPanHotkey()
    local pan=GetEquippedPan() or FindPanAnywhere()
    if pan then local slot=pan:GetAttribute("NewHotbarSlot"); if slot and SlotKeys[slot] then return SlotKeys[slot] end end
    return Enum.KeyCode.One
end

task.spawn(function()
    while _G.SigmaFarm_Running do
        task.wait(1)
        if Config.AutoTotem and not Config.IsSelling and not Config.IsGeodeCollecting and not IsShakingActionActive() then
            local Char=LocalPlayer.Character; local Root=Char and Char:FindFirstChild("HumanoidRootPart"); local Humanoid=Char and Char:FindFirstChild("Humanoid")
            if Root and Humanoid and Config.TotemSpot then
                local function placeOne(name)
                    if not Config.AutoTotem then return end
                    if tick()-(TotemPlaceCooldown[name] or 0)<90 then return end
                    if GetSpecificTotem(Config.TotemSpot,name) then return end
                    local totemTool=FindToolByName(name); if not totemTool then return end
                    local hotkey=GetToolHotkey(totemTool); if not hotkey then return end
                    Config.IsPlacingTotem=true; Config.StatusMessageOverride="Walking to place "..name.."..."
                    local walkTimeout=tick()+6
                    while Config.AutoTotem and Root and (Root.Position-Config.TotemSpot).Magnitude>6 and tick()<walkTimeout do
                        SimpleWalkTo(Config.TotemSpot); task.wait(0.15)
                    end
                    if not Config.AutoTotem then return end
                    if not Root or (Root.Position-Config.TotemSpot).Magnitude>8 then return end
                    if GetSpecificTotem(Config.TotemSpot,name) then return end
                    Config.StatusMessageOverride="Placing "..name.."..."; TotemPlaceCooldown[name]=tick()
                    PressHotkey(hotkey); task.wait(0.5)
                    local equippedTool=nil; local equipDeadline=tick()+2
                    while tick()<equipDeadline do
                        local t=Char:FindFirstChildOfClass("Tool"); if t and t.Name:find(name) then equippedTool=t; break end; task.wait(0.1)
                    end
                    if equippedTool then
                        Root.CFrame=CFrame.new(Root.Position,Config.TotemSpot); task.wait(0.15)
                        local alreadyPlaced=GetSpecificTotem(Config.TotemSpot,name)~=nil
                        if not alreadyPlaced then pcall(function() equippedTool:Activate() end); task.wait(0.4) end
                    end
                    PressHotkey(GetPanHotkey()); task.wait(0.8)
                    local verifyDeadline=tick()+5
                    while tick()<verifyDeadline do if GetSpecificTotem(Config.TotemSpot,name) then break end; task.wait(0.2) end
                    task.wait(0.3)
                end
                placeOne("Luck"); placeOne("Strength"); placeOne("Luminant")
                if Config.IsPlacingTotem then
                    Config.IsPlacingTotem=false; Config.StatusMessageOverride="Re-equipping Pan..."
                    PressHotkey(GetPanHotkey()); task.wait(1); Config.StatusMessageOverride=nil
                end
            end
        end
    end
end)

-- // AUTO WALK LOOP //
task.spawn(function()
    local lastMode=nil
    while _G.SigmaFarm_Running do
        task.wait(0.1)
        repeat
        local Char=LocalPlayer.Character; local Root=Char and Char:FindFirstChild("HumanoidRootPart"); local Humanoid=Char and Char:FindFirstChild("Humanoid")
        if not Root or not Humanoid then break end
        if not Config.AutoManualWalk or not Config.SandSpot or not Config.WaterSpot then Config.IsMoving=false; Config.CurrentTarget=nil; lastMode=nil; break end
        if Config.IsSelling or Config.IsGeodeCollecting or Config.IsPlacingTotem or Config.IsPanning then Config.IsMoving=false; lastMode=nil; break end
        local Pan=GetEquippedPan(); local fill=GetFillAmount(Pan); local cap=GetCapacity(Pan)
        local mode,target
        if fill>=cap then mode="Water"; target=Config.WaterSpot; Config.CurrentTarget="Water"
        else mode="Sand"; target=Config.SandSpot; Config.CurrentTarget="Deposit" end
        local dist=(Root.Position-target).Magnitude
        if Config.IsMoving then
            if dist<=4 then Config.IsMoving=false; lastMode=mode; Humanoid.WalkToPoint=Root.Position
            else Humanoid.WalkToPoint=target end
        else
            if lastMode~=mode or dist>8 then Config.IsMoving=true; lastMode=mode; Humanoid.WalkToPoint=target end
        end
        until true
    end
end)

-- // FARM LOOP //
local FarmLoop=RunService.Heartbeat:Connect(function(dt)
    if not _G.SigmaFarm_Running then return end
    if tick()-lockTimer>1 then
        lockTimer=tick()
        if Config.AutoSell and LockRemote then
            local backpack=LocalPlayer:FindFirstChild("BackpackTwo") or LocalPlayer:FindFirstChild("Backpack")
            if backpack then
                for _,item in pairs(backpack:GetChildren()) do
                    if Config.LockedItems[item.Name] and not Config.ProcessedInstances[item] then
                        Config.ProcessedInstances[item]=true; LockRemote:FireServer(item)
                    end
                end
            end
        end
    end
    cleanupTimer=cleanupTimer+dt
    if cleanupTimer>=10 then cleanupTimer=0; for item,_ in pairs(Config.ProcessedInstances) do if not item.Parent then Config.ProcessedInstances[item]=nil end end end
    local PanTool=GetEquippedPan()
    if not PanTool then
        MainStatusLabel.Text="Equip your Pan  (Slot 1)"; MainStatusLabel.TextColor3=Theme.Red
        TweenService:Create(StatusDot,TweenInfo.new(0.2),{BackgroundColor3=Theme.Red}):Play()
        TweenService:Create(ProgressBar,TweenInfo.new(0.4),{Size=UDim2.new(0,0,1,0)}):Play(); return
    end
    local CurrentFill=GetFillAmount(PanTool); local MaxCap=GetCapacity(PanTool)
    local StateText=GetStateLabel(); local BagCurrent,BagMax=GetInventoryStatus()
    local Char=LocalPlayer.Character; local Root=Char and Char:FindFirstChild("HumanoidRootPart"); local Humanoid=Char and Char:FindFirstChild("Humanoid")
    if tick()-debugTimer>0.1 then
        debugTimer=tick()
        pcall(function()
            local pct=math.clamp(CurrentFill/MaxCap,0,1)
            TweenService:Create(ProgressBar,TweenInfo.new(0.25),{Size=UDim2.new(pct,0,1,0)}):Play()
            local barColor=pct>=1 and Theme.Orange or Theme.Accent
            TweenService:Create(ProgressBar,TweenInfo.new(0.25),{BackgroundColor3=barColor}):Play()
            FillPctLabel.Text=math.floor(pct*100).."%"; FillPctLabel.TextColor3=pct>=1 and Theme.Orange or Theme.Accent
            if Config.StatusMessageOverride then
                MainStatusLabel.Text=Config.StatusMessageOverride; MainStatusLabel.TextColor3=Theme.Orange
                TweenService:Create(StatusDot,TweenInfo.new(0.2),{BackgroundColor3=Theme.Orange}):Play()
            else
                local status="Idle"; local dotColor=Theme.TextDim
                if Config.IsPlacingTotem then status="Placing Totem..."; dotColor=Color3.fromRGB(180,120,255)
                elseif Config.IsGeodeCollecting then status="Collecting Geodes..."; dotColor=Color3.fromRGB(80,180,255)
                elseif Config.IsSelling then status="Selling items..."; dotColor=Theme.Orange
                elseif Config.IsPanning then status="Panning..."; dotColor=Theme.Accent
                elseif Config.IsMoving then status="Walking  →  "..(Config.CurrentTarget or "?"); dotColor=Theme.Accent
                elseif CurrentFill>=MaxCap then status="Pan full — go to water"; dotColor=Theme.Orange
                elseif Config.AutoShovel then status="Digging..."; dotColor=Theme.Accent end
                MainStatusLabel.Text=string.format("%s  (%d/%d)",status,CurrentFill,MaxCap); MainStatusLabel.TextColor3=Theme.TextMain
                TweenService:Create(StatusDot,TweenInfo.new(0.2),{BackgroundColor3=dotColor}):Play()
            end
            BagLabel.Text=string.format("Bag: %d / %d%s",BagCurrent,BagMax,Config.AutoSell and "  [AUTO-SELL]" or "")
            BagLabel.TextColor3=(BagCurrent>=BagMax) and Theme.Red or Theme.TextDim
        end)
    end
    if Config.IsSelling or Config.IsGeodeCollecting or Config.IsPlacingTotem or Config.IsMoving then return end
    if Config.AutoSell and BagCurrent>=BagMax and not Config.IsSelling and not IsShakingActionActive() then
        Config.IsSelling=true
        task.spawn(function()
            local Char2=LocalPlayer.Character; local Root2=Char2 and Char2:FindFirstChild("HumanoidRootPart")
            if Root2 then
                local originalPos=Root2.Position
                local merchantPos=GetNearestMerchant(); local dist=merchantPos and (Root2.Position-merchantPos).Magnitude or math.huge
                if not merchantPos or dist>400 then
                    Config.StatusMessageOverride="Seller not found (<400 studs)!"; task.wait(3); Config.StatusMessageOverride=nil; Config.IsSelling=false; return
                end
                local function IsBagEmpty()
                    local valCount=0
                    local bp2=LocalPlayer:FindFirstChild("BackpackTwo") or LocalPlayer:FindFirstChild("Backpack")
                    if bp2 then for _,v in pairs(bp2:GetChildren()) do if v:GetAttribute("ItemType")=="Valuable" and not Config.LockedItems[v.Name] then valCount=valCount+1 end end end
                    if LocalPlayer.Character then for _,v in pairs(LocalPlayer.Character:GetChildren()) do if v:IsA("Tool") and v:GetAttribute("ItemType")=="Valuable" and not Config.LockedItems[v.Name] then valCount=valCount+1 end end end
                    return valCount==0
                end
                local function GetApproachPos(mPos)
                    local Root3=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if Root3 then
                        local dir=(Root3.Position-mPos); if dir.Magnitude>0.1 then return mPos+dir.Unit*4 end
                    end
                    return mPos+Vector3.new(4,0,0)
                end
                Config.StatusMessageOverride="Walking to merchant..."
                SmartWalkTo(GetApproachPos(merchantPos),function() return not Config.IsSelling end)
                if not Config.IsSelling then Config.IsSelling=false; return end
                local Humanoid2=Char2 and Char2:FindFirstChild("Humanoid")
                if Humanoid2 then Humanoid2:MoveTo(Root2.Position) end
                Config.StatusMessageOverride="Selling..."
                local sellAttempts=0
                while sellAttempts<8 and not IsBagEmpty() and Config.IsSelling do
                    if SellRemote then pcall(function() SellRemote:InvokeServer() end) end
                    sellAttempts=sellAttempts+1; task.wait(0.35); if IsBagEmpty() then break end
                end
                if Humanoid2 then Humanoid2:MoveTo(Root2.Position) end
                Config.StatusMessageOverride=nil
                if (Root2.Position-originalPos).Magnitude>10 then
                    Config.StatusMessageOverride="Returning..."
                    SmartWalkTo(originalPos,function() return not Config.IsSelling end)
                    Config.StatusMessageOverride=nil
                end
                if Humanoid2 then Humanoid2:MoveTo(Root2.Position) end
            end
            Config.IsSelling=false
        end)
    end
    if Config.IsSelling or Config.IsGeodeCollecting then return end
    if Config.AutoShovel and not Config.IsPanning then
        if CurrentFill<MaxCap and StateText~="Pan" then
            local collect=PanTool.Scripts:FindFirstChild("Collect")
            if collect and collect:IsA("RemoteFunction") then collect:InvokeServer(1) end
        end
    end
    if Config.AutoShake and not Config.IsPanning then
        local isLegitWater=false
        if StateText=="Pan" then
            if Root and CheckRegion(Root.Position)~="Deposit" then isLegitWater=true end
        end
        if CurrentFill>0 and isLegitWater then
            Config.IsPanning=true
            local panRemote=PanTool.Scripts:FindFirstChild("Pan"); local shakeRemote=PanTool.Scripts:FindFirstChild("Shake")
            if panRemote and shakeRemote then
                task.wait(0.3); panRemote:InvokeServer()
                local lastFill=GetFillAmount(PanTool); local lastChangeTime=tick()
                while Config.AutoShake and GetFillAmount(PanTool)>0 and GetEquippedPan() do
                    if Root and CheckRegion(Root.Position)=="Deposit" then break end
                    local currentFill=GetFillAmount(PanTool)
                    if currentFill<lastFill then lastFill=currentFill; lastChangeTime=tick()
                    elseif tick()-lastChangeTime>1.5 then panRemote:InvokeServer(); lastChangeTime=tick() end
                    shakeRemote:FireServer(); task.wait()
                end
            end
            Config.IsPanning=false
            if GetFillAmount(PanTool)==0 then Config.CurrentTarget="Deposit" end
        end
    end
end)

table.insert(_G.SigmaFarm_Connections, FarmLoop)
warn("SIGMA HUB - REMASTERED loaded successfully.")
